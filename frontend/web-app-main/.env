# Default for local dev (Docker and npm run dev).
# Browser calls this URL; use localhost when backend is on same machine.
NEXT_PUBLIC_API_URL=http://localhost:8000

# OpenAlex polite pool (optional; higher rate limits). No API key required.
# https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication#the-polite-pool
NEXT_PUBLIC_OPENALEX_EMAIL=
